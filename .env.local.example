# Supabase — using anon key (public, row-level security enforced)
# Service role key is NOT needed. This is a public read-only microsite.
# All cincy_voices_* tables should have RLS policies allowing public SELECT.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_SITE_URL=https://voices.workwithmean.ing
